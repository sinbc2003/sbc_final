    {
      "id": "gongmun_gen",
      "type": "llm_generate",
      "params": {
        "prompt_template": "다음 제목으로 학교 공문(기안문) 본문을 작성하라.\n\n[제목]\n{{입력텍스트}}",
        "lora": "gongmun",
        "provider": "local",
        "max_tokens": 700,
        "temperature": 0.3
      },
      "position": { "x": 420, "y": 200 }
    },
    {
      "id": "to_hwpx",
      "type": "md_to_hwpx",
      "params": { "output_name": "공문_초안" },
      "position": { "x": 740, "y": 200 }
    }
  ],
  "edges": [
    { "from": "title_input", "from_port": "텍스트", "to": "gongmun_gen", "to_port": "입력텍스트" },
    { "from": "gongmun_gen", "from_port": "출력텍스트", "to": "to_hwpx", "to_port": "텍스트" }
  ],
  "user_inputs": [
